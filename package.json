{
  "name": "react",
  "author": "Anton G. Neuhold Jr",
  "license": "ISC",
  "packageManager": "pnpm@10.18.2",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "rimraf out && next build --no-lint --turbopack",
    "analyze": "rimraf out && ANALYZE=true next build --no-lint",
    "start": "pnpm run build && serve out",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "nutrition:meals": "tsx 'app/(routes)/nutrition/scripts/printMealPlans.ts'",
    "nutrition:optimize": "tsx 'app/(routes)/nutrition/scripts/optimizeMealPlan.ts'",
    "nutrition:targets": "tsx 'app/(routes)/nutrition/scripts/analyzeCalorieTargets.ts'"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.5.6",
    "next-export-optimize-images": "^4.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@aneuhold/eslint-config": "^1.3.10",
    "@inquirer/prompts": "^8.4.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.38.0",
    "netlify-cli": "^23.9.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
